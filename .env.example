# Supabase est optionnel : sans ces variables, l'app reste en localStorage.
# Ajoute ces variables dans Vercel + dans un fichier local .env.local.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# CalSnap — reconnaissance photo (Claude vision). Clé SERVEUR uniquement,
# jamais préfixée NEXT_PUBLIC_ (ne doit pas être exposée au navigateur).
# Sans cette clé, le bouton "Snap" renvoie une erreur claire.
ANTHROPIC_API_KEY=
