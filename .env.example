# Supabase est optionnel : sans ces variables, l'app reste en localStorage.
# Ajoute ces variables dans Vercel + dans un fichier local .env.local.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# CalSnap — reconnaissance photo. Clé SERVEUR uniquement (jamais NEXT_PUBLIC_).
# Mets AU MOINS une des deux clés ci-dessous. Si les deux sont présentes,
# Gemini (gratuit) est utilisé en priorité.
#
# Option GRATUITE (recommandée) : Google Gemini.
#   Crée une clé sur https://aistudio.google.com/app/apikey (gratuit).
#   Offre gratuite : ~10 req/min, ~1500 req/jour. Modèle par défaut : gemini-2.5-flash.
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash   # optionnel, pour changer de modèle

# Option PAYANTE : Anthropic Claude (https://console.anthropic.com).
ANTHROPIC_API_KEY=
